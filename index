<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--g:#3CC13B;--dk:#1A1A1A;--gl:#EBF9EB;--gm:#C5ECC4;--gray:#F5F5F5;--bdr:#E0E0E0;--mt:#888;--tx:#1A1A1A}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Arial,sans-serif;background:#fff;color:var(--tx);font-size:13px}
.hdr{background:#000;padding:13px 20px;display:flex;align-items:center;justify-content:space-between;border-bottom:3px solid var(--g)}
.hdr-cenco{font-size:13px;font-weight:400;color:#fff;letter-spacing:.5px}
.hdr-prime{font-size:26px;font-weight:900;color:#fff;letter-spacing:-0.5px;line-height:1;display:flex;align-items:flex-start}
.hdr-dot{color:var(--g);font-size:32px;line-height:.7;font-weight:900}
.hdr-badge{background:rgba(60,193,59,.15);color:var(--g);font-size:11px;font-weight:600;padding:4px 12px;border-radius:20px;border:1px solid rgba(60,193,59,.3)}
.kbar{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid var(--bdr)}
.kc{padding:10px 16px;border-right:1px solid var(--bdr)}.kc:last-child{border-right:none}
.kl{font-size:10px;color:var(--mt);text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px}
.kv{font-size:19px;font-weight:700;color:var(--dk)}
.ks{font-size:11px;margin-top:2px}.up{color:#27A026}.dn{color:#C0392B}.neu{color:var(--mt)}
.main{display:grid;grid-template-columns:1fr 1fr;min-height:calc(100vh - 110px)}
.panel{padding:14px 16px;border-right:1px solid var(--bdr);background:#fff;overflow-y:auto}.panel:last-child{border-right:none}
.ptitle{font-size:13px;font-weight:700;color:var(--dk);padding-bottom:8px;border-bottom:2px solid var(--g);margin-bottom:11px;display:flex;align-items:center;gap:6px}
.picon{width:20px;height:20px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:11px;background:var(--gl)}
.flbl{font-size:10px;font-weight:700;color:var(--mt);text-transform:uppercase;letter-spacing:.06em;margin-bottom:5px}
.pills{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px}
.pill{font-size:11px;padding:4px 10px;border-radius:20px;border:1.5px solid var(--bdr);color:var(--mt);cursor:pointer;background:#fff;transition:all .15s;user-select:none}
.pill:hover{border-color:var(--g);color:var(--dk)}.pill.on{background:var(--dk);color:#fff;border-color:var(--dk)}
.mkpis{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:10px}
.mk{background:var(--gray);border-radius:7px;padding:8px 10px}
.ml{font-size:10px;color:var(--mt);margin-bottom:2px}
.mv{font-size:16px;font-weight:700;color:var(--dk)}
.cbox{position:relative;width:100%;margin-bottom:10px}
.leg{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:7px}
.leg-i{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--mt)}
.leg-sq{width:10px;height:10px;border-radius:2px;flex-shrink:0;display:inline-block}
.leg-line{width:18px;height:3px;border-radius:2px;flex-shrink:0;display:inline-block}
.dtitle{font-size:10px;font-weight:700;color:var(--mt);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
.pb{margin-bottom:5px;border:1px solid var(--bdr);border-radius:7px;overflow:hidden}
.ph{display:flex;align-items:center;gap:8px;padding:7px 10px;background:var(--gray);cursor:pointer}
.ph:hover{background:#ebebeb}
.phdot{width:7px;height:7px;border-radius:50%;flex-shrink:0;background:var(--g)}
.phn{flex:1;font-weight:700;font-size:12px;color:var(--dk)}
.phbw{width:60px;height:5px;background:var(--bdr);border-radius:3px;overflow:hidden}
.phb{height:100%;border-radius:3px;background:var(--g)}
.pht{font-weight:700;font-size:12px;color:var(--dk);min-width:44px;text-align:right}
.php{font-size:11px;font-weight:700;padding:2px 6px;border-radius:10px;background:var(--gl);color:#27A026;min-width:32px;text-align:center}
.phc{font-size:11px;color:var(--mt);transition:transform .2s;width:13px;text-align:center;display:inline-block}
.phc.op{transform:rotate(180deg)}
.prods{display:none;border-top:1px solid var(--bdr)}.prods.op{display:block}
.prods-always{display:block;border-top:1px solid var(--bdr)}
.pr{display:flex;flex-direction:column;gap:3px;padding:8px 10px 8px 22px;border-bottom:1px solid #f5f5f5}.pr:last-child{border-bottom:none}
.pr-top{display:flex;align-items:center;gap:7px}
.prn{flex:1;font-size:11px;color:var(--dk);font-weight:600}
.pr-desc{font-size:10px;color:var(--mt);line-height:1.4}
.prbw{width:46px;height:4px;background:var(--bdr);border-radius:2px;overflow:hidden}
.prb{height:100%;border-radius:2px;background:var(--gm)}
.prv{font-size:11px;color:var(--mt);min-width:34px;text-align:right;font-weight:600}
.sbtns{display:flex;gap:5px;margin-bottom:5px}
.sbtn{font-size:10px;padding:3px 8px;border-radius:11px;border:1px solid var(--bdr);background:transparent;color:var(--mt);cursor:pointer}
.sbtn:hover{background:var(--gray)}
.empty{text-align:center;padding:24px;color:var(--mt);font-size:12px}
.mpills{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px}
.mpill{font-size:10px;padding:3px 8px;border-radius:12px;border:1px solid var(--bdr);color:var(--mt);cursor:pointer;background:#fff}
.mpill:hover{border-color:var(--g)}.mpill.on{background:var(--g);color:#fff;border-color:var(--g)}
.ybtns{display:flex;gap:4px;margin-bottom:6px}
.ybtn{font-size:10px;padding:3px 9px;border-radius:11px;border:1.5px solid var(--bdr);background:#fff;color:var(--mt);cursor:pointer;font-weight:600}
.ybtn.on{background:var(--dk);color:#fff;border-color:var(--dk)}
.ybtn:hover:not(.on){border-color:var(--g)}
.ptabs{display:flex;gap:4px;margin-bottom:10px;flex-wrap:wrap}
.ptab{font-size:11px;padding:4px 10px;border-radius:20px;border:1.5px solid var(--bdr);color:var(--mt);cursor:pointer;background:#fff;font-weight:500;transition:all .15s}
.ptab.on{color:#fff;border-color:transparent}
.ptab:hover:not(.on){border-color:var(--g)}
.pmetrics{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:8px}
.pmet{background:var(--gray);border-radius:6px;padding:7px 10px}
.pmet-l{font-size:10px;color:var(--mt);margin-bottom:2px;line-height:1.3}
.pmet-v{font-size:15px;font-weight:700;color:var(--dk)}
.hint-box{background:#F0FFF0;border:1px solid #C5ECC4;border-radius:6px;padding:7px 10px;margin-bottom:10px;font-size:11px;color:#1A5C1A;line-height:1.6}
.footer{text-align:center;padding:10px;font-size:10px;color:#aaa;border-top:1px solid var(--bdr)}
</style>
</head>
