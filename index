const EST_PARTNERS=["RINCON DEL JUMBO","CABIFY","COPEC","CENCO MALLS"];
const MONTH_ORDER=["Mar-25","Abr-25","May-25","Jun-25","Jul-25","Ago-25","Sep-25","Oct-25","Nov-25","Dic-25","Ene-26","Feb-26","Mar-26","Abr-26","May-26","Jun-26"];
const PW_PALETTE=["#C5ECC4","#8DD98C","#3CC13B","#27A026","#1A7A19"];
const PARTNER_COLORS=["#3CC13B","#27A026","#1A7A19","#0F5210","#8DD98C","#C5ECC4","#6B3A2A","#0097C4","#7B3FAF","#185FA5"];
const YEARS=["2025","2026"];

let selPWs=new Set(["2a 2026"]),selPartner="RINCON DEL JUMBO",selMonths=new Set(MONTH_ORDER),selYears=new Set(YEARS),pwC=null,eC=null;
const fmt=n=>Math.round(n).toLocaleString("es-CL");
const ptotal=pw=>Object.values(PW_DATA[pw].partners).flatMap(p=>p).reduce((s,x)=>s+x.usos,0);
const ppartner=(pw,p)=>PW_DATA[pw].partners[p]?PW_DATA[pw].partners[p].reduce((s,x)=>s+x.usos,0):0;

function buildKPIs(){
  document.getElementById("kpi-bar").innerHTML=EST_PARTNERS.map(p=>{
    const d=EST_DATA[p].data["Jun-26"];if(!d)return"";
    const mom=d.mom,mcls=mom==null?"neu":mom>=0?"up":"dn";
    const msign=mom==null?"–":((mom>=0?"+":"")+(mom*100).toFixed(1)+"%");
    return`<div class="kc" style="border-left:3px solid ${EST_DATA[p].color}">
      <div class="kl">${p} · Jun-26</div>
      <div class="kv">${fmt(d.usos)}</div>
      <div class="ks ${mcls}">${msign} vs May-26</div>
    </div>`;
  }).join("");
}

function getM(){return MONTH_ORDER.filter(m=>selMonths.has(m)&&selYears.has("20"+m.slice(-2)))}

function bPW(){
  const c=document.getElementById("pw-pills");c.innerHTML="";
  PW_ORDER.forEach(pw=>{
    const b=document.createElement("button");
    b.className="pill"+(selPWs.has(pw)?" on":"");
    b.innerHTML=`<b>${pw}</b> · ${PW_DATA[pw].fecha}`;
    b.onclick=()=>{selPWs.has(pw)?selPWs.delete(pw):selPWs.add(pw);bPW();rPW()};
    c.appendChild(b);
  });
}

function bEstTabs(){
  const c=document.getElementById("est-tabs");c.innerHTML="";
  EST_PARTNERS.forEach(p=>{
    const b=document.createElement("button");
    b.className="ptab"+(selPartner===p?" on":"");
    if(selPartner===p){b.style.background=EST_DATA[p].color;b.style.borderColor=EST_DATA[p].color}
    b.textContent=p;
    b.onclick=()=>{selPartner=p;bEstTabs();rEst()};
    c.appendChild(b);
  });
}

function bYears(){
  const c=document.getElementById("yr-btns");c.innerHTML="";
  YEARS.forEach(y=>{
    const b=document.createElement("button");
    b.className="ybtn"+(selYears.has(y)?" on":"");
    b.textContent=y;
    b.onclick=()=>{selYears.has(y)?selYears.delete(y):selYears.add(y);bYears();bMonths();rEst()};
    c.appendChild(b);
  });
}

function bMonths(){
  const c=document.getElementById("m-pills");c.innerHTML="";
  MONTH_ORDER.filter(m=>selYears.has("20"+m.slice(-2))).forEach(m=>{
    const b=document.createElement("button");
    b.className="mpill"+(selMonths.has(m)?" on":"");
    b.textContent=m;
    b.onclick=()=>{selMonths.has(m)?selMonths.delete(m):selMonths.add(m);bMonths();rEst()};
    c.appendChild(b);
  });
}

function selAllPW(){PW_ORDER.forEach(pw=>selPWs.add(pw));bPW();rPW()}
function clrPW(){selPWs.clear();bPW();rPW()}
function selAllM(){MONTH_ORDER.forEach(m=>selMonths.add(m));bMonths();rEst()}
function clrM(){selMonths.clear();bMonths();rEst()}
function tog(id){document.getElementById("prods-"+id)?.classList.toggle("op");document.getElementById("chev-"+id)?.classList.toggle("op")}

function buildProdRows(items){
  const mp=Math.max(...items.map(x=>x.usos),1);
  return items.map(x=>`
    <div class="pr">
      <div class="pr-top">
        <span class="prn">${x.prod}</span>
        <div class="prbw"><div class="prb" style="width:${Math.round(x.usos/mp*100)}%"></div></div>
        <span class="prv">${fmt(x.usos)}</span>
      </div>
      <div class="pr-desc">${x.desc}</div>
    </div>`).join("");
}

function rPW(){
  const act=PW_ORDER.filter(pw=>selPWs.has(pw));
  if(!act.length){
    ["pw-tot","pw-pts","pw-eds"].forEach(id=>document.getElementById(id).textContent="–");
    document.getElementById("pw-eds").textContent="0";
    document.getElementById("pw-leg").innerHTML="";
    document.getElementById("pw-det").innerHTML='<div class="empty">Selecciona al menos una Prime Week</div>';
    if(pwC){pwC.destroy();pwC=null}return;
  }

  const grand=act.reduce((s,pw)=>s+ptotal(pw),0);
  const allP=[...new Set(act.flatMap(pw=>Object.keys(PW_DATA[pw].partners)))];
  document.getElementById("pw-tot").textContent=fmt(grand);
  document.getElementById("pw-pts").textContent=allP.length;
  document.getElementById("pw-eds").textContent=act.length;

  const ctx=document.getElementById("pw-chart").getContext("2d");
  if(pwC){pwC.destroy();pwC=null}

  if(act.length===1){
    const pw=act[0];
    const pT=Object.entries(PW_DATA[pw].partners)
      .map(([p,items])=>[p,items.reduce((s,x)=>s+x.usos,0)])
      .sort((a,b)=>b[1]-a[1]);
    document.getElementById("pw-leg").innerHTML="";
    pwC=new Chart(ctx,{type:"bar",data:{labels:pT.map(([p])=>p),datasets:[{data:pT.map(([,u])=>u),backgroundColor:pT.map((_,i)=>PW_PALETTE[Math.min(i,PW_PALETTE.length-1)]),borderRadius:4,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:v=>"Usos: "+fmt(v.raw)}}},scales:{x:{grid:{display:false},ticks:{font:{size:10},color:"#888",maxRotation:35,autoSkip:false}},y:{grid:{color:"#f5f5f5"},ticks:{font:{size:10},color:"#888",callback:v=>fmt(v)}}}}});

    const mxP=pT[0]?.[1]||1;
    document.getElementById("pw-det").innerHTML=pT.map(([p,total],i)=>{
      const items=[...PW_DATA[pw].partners[p]].sort((a,b)=>b.usos-a.usos);
      const bw=Math.round(total/mxP*100),pct=Math.round(total/grand*100);
      const hm=items.length>1;
      const prodHTML=buildProdRows(items);
      return`<div class="pb">
        <div class="ph" onclick="${hm?`tog('pw${i}')`:''}" style="${hm?'':'cursor:default'}">
          <div class="phdot"></div>
          <span class="phn">${p}</span>
          <div class="phbw"><div class="phb" style="width:${bw}%"></div></div>
          <span class="pht">${fmt(total)}</span>
          <span class="php">${pct}%</span>
          ${hm?`<span class="phc" id="chev-pw${i}">▾</span>`:'<span style="width:13px"></span>'}
        </div>
        ${hm
          ? `<div class="prods" id="prods-pw${i}">${prodHTML}</div>`
          : `<div class="prods-always">${prodHTML}</div>`
        }
      </div>`;
    }).join("");

  } else {
    const pcMap={};allP.forEach((p,i)=>{pcMap[p]=PARTNER_COLORS[i%PARTNER_COLORS.length]});
    document.getElementById("pw-leg").innerHTML=allP.map(p=>`<span class="leg-i"><span class="leg-sq" style="background:${pcMap[p]}"></span>${p}</span>`).join("");
    const ds=allP.map(p=>({label:p,data:act.map(pw=>ppartner(pw,p)),backgroundColor:pcMap[p],borderRadius:0,borderSkipped:false}));
    if(ds.length>0)ds[ds.length-1].borderRadius=4;
    pwC=new Chart(ctx,{type:"bar",data:{labels:act.map(pw=>pw+" · "+PW_DATA[pw].fecha),datasets:ds},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{mode:"index",intersect:false,callbacks:{label:v=>v.raw>0?`${v.dataset.label}: ${fmt(v.raw)}`:'',footer:items=>"Total: "+fmt(items.reduce((s,i)=>s+(i.raw||0),0))}}},scales:{x:{stacked:true,grid:{display:false},ticks:{font:{size:10},color:"#888",maxRotation:25,autoSkip:false}},y:{stacked:true,grid:{color:"#f5f5f5"},ticks:{font:{size:10},color:"#888",callback:v=>fmt(v)}}}}});

    const mxPW=Math.max(...act.map(pw=>ptotal(pw)));
    document.getElementById("pw-det").innerHTML=act.map((pw,i)=>{
      const total=ptotal(pw),pct=Math.round(total/grand*100),bw=Math.round(total/mxPW*100);
      const sub=Object.entries(PW_DATA[pw].partners).map(([p,items])=>{
        const u=items.reduce((s,x)=>s+x.usos,0);
        return`<div style="border-bottom:1px solid #f0f0f0">
          <div style="display:flex;align-items:center;gap:8px;padding:6px 10px 4px 22px">
            <span class="leg-sq" style="background:${pcMap[p]||'#3CC13B'};flex-shrink:0"></span>
            <span style="flex:1;font-size:12px;font-weight:700;color:var(--dk)">${p}</span>
            <span style="font-size:11px;font-weight:600;color:var(--mt)">${fmt(u)}</span>
          </div>
          ${buildProdRows(items)}
        </div>`;
      }).join("");
      return`<div class="pb">
        <div class="ph" onclick="tog('pw${i}')">
          <div class="phdot" style="background:${PW_PALETTE[i%PW_PALETTE.length]}"></div>
          <span class="phn">${pw} · ${PW_DATA[pw].fecha}</span>
          <div class="phbw"><div class="phb" style="width:${bw}%;background:${PW_PALETTE[i%PW_PALETTE.length]}"></div></div>
          <span class="pht">${fmt(total)}</span>
          <span class="php">${pct}%</span>
          <span class="phc" id="chev-pw${i}">▾</span>
        </div>
        <div class="prods" id="prods-pw${i}">${sub}</div>
      </div>`;
    }).join("");
  }
}

function rEst(){
  const p=selPartner;
  const color=EST_DATA[p].color;
  const cfg=EST_CFG[p];

  document.getElementById("est-hint").innerHTML=cfg.hint;

  const months=getM().filter(m=>EST_DATA[p].data[m]);

  // Leyenda con labels contextuales — sin penetración (va solo en el detalle)
  document.getElementById("est-leg").innerHTML=`
    <span class="leg-i"><span class="leg-sq" style="background:${color}"></span>${cfg.labelUsos}</span>
    <span class="leg-i"><span class="leg-sq" style="background:${color};opacity:.35"></span>${cfg.labelCli}</span>
    <span class="leg-i"><span class="leg-line" style="background:#E8580D"></span>${cfg.labelUpc}</span>`;

  const ctx=document.getElementById("est-chart").getContext("2d");
  if(eC)eC.destroy();

  if(!months.length){
    document.getElementById("est-det").innerHTML='<div class="empty">Sin datos en el período seleccionado</div>';
    return;
  }

  // Gráfico combinado: barras (usos + clientes) + línea (usos/cliente, número no %)
  eC=new Chart(ctx,{
    data:{
      labels:months,
      datasets:[
        {type:"bar",label:cfg.labelUsos,data:months.map(m=>EST_DATA[p].data[m]?.usos||null),backgroundColor:color+"CC",borderRadius:3,borderSkipped:false,yAxisID:"y",order:2},
        {type:"bar",label:cfg.labelCli,data:months.map(m=>EST_DATA[p].data[m]?.cli||null),backgroundColor:color+"33",borderRadius:3,borderSkipped:false,yAxisID:"y",order:3},
        {type:"line",label:cfg.labelUpc,data:months.map(m=>EST_DATA[p].data[m]?.upc||null),borderColor:"#E8580D",backgroundColor:"transparent",tension:.35,pointRadius:3,pointHoverRadius:5,borderWidth:2.5,yAxisID:"y2",spanGaps:true,order:1}
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{mode:"index",intersect:false,callbacks:{
          label:v=>`${v.dataset.label}: ${v.dataset.yAxisID==="y2"?v.raw.toFixed(2):fmt(v.raw)}`
        }}
      },
      scales:{
        x:{grid:{display:false},ticks:{font:{size:9},color:"#888",autoSkip:true,maxTicksLimit:12,maxRotation:35}},
        y:{position:"left",grid:{color:"#f5f5f5"},ticks:{font:{size:9},color:"#888",callback:v=>v>=1000?(v/1000).toFixed(0)+"k":v}},
        y2:{position:"right",grid:{display:false},ticks:{font:{size:9},color:"#E8580D",callback:v=>v.toFixed(1)},title:{display:true,text:cfg.labelUpc,font:{size:9},color:"#E8580D"}}
      }
    }
  });

  const lM=months[months.length-1];
  const d=EST_DATA[p].data[lM];
  document.getElementById("est-det-title").textContent=`Detalle ${lM} · ${p}`;
  document.getElementById("est-det").innerHTML=`
    <div class="pmetrics">
      <div class="pmet"><div class="pmet-l">${cfg.labelUsos}</div><div class="pmet-v" style="color:${color}">${fmt(d.usos)}</div></div>
      <div class="pmet"><div class="pmet-l">${cfg.labelBase}</div><div class="pmet-v">${fmt(d.base)}</div></div>
      <div class="pmet"><div class="pmet-l">${cfg.labelPen}</div><div class="pmet-v">${(d.pen*100).toFixed(1)}%</div></div>
      <div class="pmet"><div class="pmet-l">${cfg.labelCli}</div><div class="pmet-v">${fmt(d.cli)}</div></div>
      <div class="pmet"><div class="pmet-l">${cfg.labelUpc}</div><div class="pmet-v">${d.upc.toFixed(2)}</div></div>
      <div class="pmet"><div class="pmet-l">MoM</div><div class="pmet-v" style="color:${d.mom!=null?(d.mom>=0?'#27A026':'#C0392B'):'#888'}">${d.mom!=null?((d.mom>=0?'+':'')+(d.mom*100).toFixed(1)+'%'):'–'}</div></div>
    </div>`;
}

buildKPIs();bPW();bEstTabs();bYears();bMonths();rPW();rEst();
</script>
</body>
</html>
